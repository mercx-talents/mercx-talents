# ─── SERVER ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/mercx_talents

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_make_it_very_long_and_random_123456789
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_very_long_987654321
JWT_REFRESH_EXPIRE=30d

# ─── CLIENT ───────────────────────────────────────────────────
CLIENT_URL=https://mercx.site

# ─── EMAIL (Gmail) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Mercx Talents <noreply@mercx.site>

# ─── CLOUDINARY (File Uploads) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── STRIPE (International Payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# ─── PAYSTACK (African Payments) ──────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ─── PLATFORM SETTINGS ────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
MIN_WITHDRAWAL=50

# ─── ADMIN ACCOUNT (auto-created on first boot) ───────────────
# Set these in Render → Environment Variables
# NEVER commit real values to GitHub
ADMIN_EMAIL=sadikumar877@gmail.com
ADMIN_PASSWORD=Mercury001
ADMIN_NAME=Sadi Kumar
